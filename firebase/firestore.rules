rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function emailVerified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
